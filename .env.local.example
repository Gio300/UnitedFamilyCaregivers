# UnitedFamilyCaregivers - Environment variables
# Copy to .env.local and fill in your values

# Supabase (from project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# LiveKit (from cloud.livekit.io)
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# API base - where the AI Gateway is reachable (required for Chat, AI Reply, Eligibility)
# Local dev: http://localhost:7501 (run: cd ai-gateway && npm start)
# Deployed (GitHub Pages) - set in GitHub Secrets:
#   - UFC (Caddy from PC): https://api.unitedfamilycaregivers.com
#   - Kloudy shared: https://api.kloudykare.com (Caddy 8080 + cloudflared)
#   - Quick tunnel: https://xxx.trycloudflare.com (cloudflared tunnel --url http://localhost:7501)
NEXT_PUBLIC_API_BASE=http://localhost:7501

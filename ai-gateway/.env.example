# AI Gateway - Environment variables
# Copy to .env and fill in
#
# AI flow: Browser -> Cloudflare Tunnel (NEXT_PUBLIC_API_BASE) -> AI Gateway -> Ollama
# Run cloudflared tunnel to expose AI Gateway. Ollama (llama3.2, llama3.3) runs locally.

PORT=7501
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL_FAST=llama3.2:3b
OLLAMA_MODEL_SMART=llama3.3

# Must use UnitedFamilyCaregivers Supabase project (not KloudyKare)
# Run scripts/sync-ai-gateway-env.ps1 to copy from .env.local
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Email (Gmail SMTP) - for Message Center send
MESSAGING_SMTP_HOST=smtp.gmail.com
MESSAGING_SMTP_PORT=587
MESSAGING_SMTP_USER=
MESSAGING_SMTP_PASS=
MESSAGING_FROM_EMAIL=
MESSAGING_FROM_NAME=United Family Caregivers

# Nevada Medicaid Eligibility (KloudyKare logic - TOTP, open portal, check)
NEVADA_MEDICAID_USER_ID=
NEVADA_MEDICAID_PASSWORD=
NEVADA_MEDICAID_TOTP_SECRET=

# AI Gateway - Environment variables
# Copy to .env and fill in
#
# AI flow: Browser -> Cloudflare Tunnel (NEXT_PUBLIC_API_BASE) -> AI Gateway -> Ollama
# Run cloudflared tunnel to expose AI Gateway. Ollama (llama3.2, llama3.3) runs locally.

PORT=7501
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL_FAST=llama3.2
OLLAMA_MODEL_SMART=llama3.3

# Must use UnitedFamilyCaregivers Supabase project (not KloudyKare)
# Run scripts/sync-ai-gateway-env.ps1 to copy from .env.local
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Same as NEXT_PUBLIC_LIVEKIT_URL (wss://…). Required for GET /api/livekit/room-status (Room Service API).
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
# LiveKit Agent dispatch name for cs-voice-* rooms. Must match the agent name in LiveKit Cloud
# (Agent Builder), e.g. Kloudy. If you run the self-hosted Node worker instead, set this to
# ufc-cs-agent and do NOT also run the Cloud agent for the same rooms (double join).
LIVEKIT_AGENT_NAME=Kloudy

# Optional: Supabase service role — required for /api/dev/* profile admin and developer_allowlist upserts
#SUPABASE_SERVICE_ROLE_KEY=

# Developer console (gateway): comma-separated emails allowed to call /api/dev/* ; optional table public.developer_allowlist
#DEVELOPER_ALLOW_EMAILS=you@example.com

# Outbound SIP (LiveKit Cloud outbound trunk ID from Telephony). Required for POST /api/telephony/outbound
#LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
# Comma-separated E.164 allowlist (must include any number you dial)
#OUTBOUND_DIAL_ALLOWLIST=+18334326588,+18005252395

# Nevada Medicaid / Gainwell-style outbound preset (optional). When set, preset key nv_medicaid appears in GET /api/telephony/lines
#NEVADA_MEDICAID_OUTBOUND_E164=
#NEVADA_MEDICAID_SIP_DTMF=1w4

# Email (Gmail SMTP) - for Message Center send
MESSAGING_SMTP_HOST=smtp.gmail.com
MESSAGING_SMTP_PORT=587
MESSAGING_SMTP_USER=
MESSAGING_SMTP_PASS=
MESSAGING_FROM_EMAIL=
MESSAGING_FROM_NAME=United Family Caregivers

# Nevada Medicaid Eligibility (KloudyKare logic - TOTP, open portal, check)
NEVADA_MEDICAID_USER_ID=
NEVADA_MEDICAID_PASSWORD=
NEVADA_MEDICAID_TOTP_SECRET=

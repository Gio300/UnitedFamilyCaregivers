# UFC AI Gateway - Docker Compose
# Copy to .env and fill in. OLLAMA_URL is overridden in docker-compose.yml.

PORT=7501
# When using Docker Compose: OLLAMA_URL=http://ollama:11434 (set in docker-compose.yml)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL_FAST=llama3.2:3b
OLLAMA_MODEL_SMART=llama3.3

# UFC Supabase project (not KloudyKare)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Nevada Medicaid Eligibility (optional)
NEVADA_MEDICAID_USER_ID=
NEVADA_MEDICAID_PASSWORD=
NEVADA_MEDICAID_TOTP_SECRET=

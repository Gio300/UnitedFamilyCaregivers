# UnitedFamilyCaregivers - Local development
# Use: caddy run --config caddy/Caddyfile.local
# Access: http://localhost:7502
# Caddy proxies /api/* to AI Gateway on port 7501

:7502 {
	handle /api/* {
		reverse_proxy localhost:7501 {
			stream_timeout 5m
		}
	}
	handle {
		respond "UnitedFamilyCaregivers API (local)" 200
	}
}

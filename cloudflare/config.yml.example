# Cloudflare Tunnel config for UnitedFamilyCaregivers
# 1. Install cloudflared: https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/install-and-setup/installation/
# 2. Run: cloudflared tunnel login
# 3. Run: cloudflared tunnel create ufc-api
# 4. Copy this file to ~/.cloudflared/config.yml and fill in <TUNNEL_ID>
# 5. Run: cloudflared tunnel run ufc-api
#
# Quick test (no config): cloudflared tunnel --url http://localhost:7501
#   Gives temporary xxx.trycloudflare.com URL. Use as NEXT_PUBLIC_API_BASE.

tunnel: <TUNNEL_ID>
credentials-file: C:\Users\<YOUR_USERNAME>\.cloudflared\<TUNNEL_ID>.json

ingress:
  # Direct to AI Gateway (7501) - simplest, no Caddy needed
  - hostname: api.kloudykare.com
    service: http://localhost:7501
  # Or via Caddy (8080) if you run Caddyfile.tunnel
  # - hostname: api.kloudykare.com
  #   service: http://localhost:8080
  - service: http_status:404
